#, c-format
msgid ""
"Bad FAT: unterminated chain for %s.  You should run dosfsck or scandisk."
msgstr ""
"FAT errado: cadeia para %s não terminada. Deve executar dosfsck ou scandisk."

#: libparted/fs/r/fat/count.c:106
#, c-format
